# =========================================================================
# Template Environment Configuration for Universal Desktop AI Copilot
# Copy this file to '.env' and fill in your actual credentials.
# =========================================================================

# --- Supabase Database Configuration (used by go-ai-backend)
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your-supabase-service-role-key-jwt-token

# --- API Gateway Authentication (used by backend-gateway & tests)
API_KEY=your-custom-gateway-api-key
PORT=8080

# --- Database Credentials (used by backend-gateway, ai-backend, and go-ai-backend)
# Connection DSN for PostgreSQL:
DATABASE_URL=postgres://postgres:password@localhost:5432/postgres

# Individual database credentials for YAML configuration (used by ai-backend):
AI_BACKEND_DB_HOST=localhost
AI_BACKEND_DB_PORT=5432
AI_BACKEND_DB_USER=postgres
AI_BACKEND_DB_PASSWORD=password
AI_BACKEND_DB_NAME=ai_backend
